# ForgeTrack Environment Configuration
# Copy this file and fill in real values — never commit the filled-in version
#
# On servers this file is generated automatically by the install script.
# For local development: cp .env.example .env.development and fill in values.

# App
NODE_ENV=development          # development | staging | production
PORT=3000
APP_NAME=ForgeTrack
APP_ENV=development           # controls the environment badge in the UI

# Security — generate with: openssl rand -hex 48
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_48

# Database
DATABASE_URL=postgresql://forgetrack:CHANGE_ME_db_password@localhost:5432/forgetrack

# Cookies
COOKIE_SECURE=false           # set true when running behind HTTPS
TRUST_PROXY=false             # set true if behind a reverse proxy (nginx etc)
COOKIE_MAX_AGE_HOURS=72
