{
  "name": "forgetrack",
  "version": "0.1.0",
  "description": "Self-hosted issue tracking — vanilla HTML/CSS/JS + Node.js/Express + SQLite",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "NODE_ENV=development nodemon server/index.js",
    "dev:win": "set NODE_ENV=development && nodemon server/index.js",
    "setup": "node server/db/migrate.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "otplib": "^12.0.1",
    "uuid": "^9.0.0",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
