# Dependencies
node_modules/

# Data & logs
data/
*.db
*.db-shm
*.db-wal
*.log
.DS_Store

# Environment files — NEVER commit these, they contain secrets
.env
.env.*

# Runtime overrides (toggled via Settings UI)
.runtime-overrides.json

# Keep only the example template
!.env.example

# User-uploaded files — stored on disk, never committed
# Back these up separately (e.g. rsync, Proxmox snapshot)
uploads/
